---
// Footer.astro — Premium footer with columns, social links, and copyright
const year = new Date().getFullYear();

const services = [
  "Reparación de Equipos",
  "Mantenimiento Preventivo",
  "Dispositivos Móviles",
  "Gestión de Garantías",
  "Capacitación",
  "Instalación",
];

const socials = [
  { name: "LinkedIn", href: "#", icon: "linkedin" },
  { name: "Facebook", href: "#", icon: "facebook" },
  { name: "WhatsApp", href: "#", icon: "whatsapp" },
];
---

<footer class="bg-secondary text-white">
  <!-- Top wave -->
  <div class="w-full leading-none">
    <svg
      viewBox="0 0 1440 60"
      xmlns="http://www.w3.org/2000/svg"
      preserveAspectRatio="none"
      class="w-full h-12 fill-canvas dark:fill-slate-950"
    >
      <path d="M0,30 C360,80 1080,-20 1440,30 L1440,0 L0,0 Z"></path>
    </svg>
  </div>

  <div class="container-lg py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand column -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-2 mb-4">
          <span
            class="flex items-center justify-center w-9 h-9 rounded-lg bg-accent text-primary font-bold text-lg leading-none"
            >H·W</span
          >
          <span class="text-xl font-extrabold tracking-tight">
            Hard<span class="text-accent">-</span>Ware
          </span>
        </div>
        <p class="text-sm text-white/60 leading-relaxed mb-6">
          Expertos en reparación y mantenimiento de equipos industriales de
          control en Monterrey, N.L. Cuidamos tu operación.
        </p>
        <!-- Socials -->
        <div class="flex gap-3">
          <a
            href="#"
            aria-label="LinkedIn"
            target="_blank"
            class="flex items-center justify-center w-9 h-9 rounded-full border border-white/20 text-white/60 hover:border-accent hover:text-accent transition-all duration-300"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
              ></path></svg
            >
          </a>
          <a
            href="#"
            aria-label="Facebook"
            target="_blank"
            class="flex items-center justify-center w-9 h-9 rounded-full border border-white/20 text-white/60 hover:border-accent hover:text-accent transition-all duration-300"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
              ></path></svg
            >
          </a>
          <a
            href="https://wa.me/528183652769"
            aria-label="WhatsApp"
            target="_blank"
            class="flex items-center justify-center w-9 h-9 rounded-full border border-white/20 text-white/60 hover:border-accent hover:text-accent transition-all duration-300"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
              ></path></svg
            >
          </a>
        </div>
      </div>

      <!-- Services column -->
      <div>
        <h3
          class="text-sm font-semibold uppercase tracking-widest text-accent mb-5"
        >
          Servicios
        </h3>
        <ul class="space-y-2.5">
          {
            services.map((s) => (
              <li>
                <a
                  href="/#services"
                  class="text-sm text-white/60 hover:text-white transition-colors duration-200 flex items-center gap-2"
                >
                  <span class="w-1 h-1 rounded-full bg-accent shrink-0" />
                  {s}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Quick links column -->
      <div>
        <h3
          class="text-sm font-semibold uppercase tracking-widest text-accent mb-5"
        >
          Empresa
        </h3>
        <ul class="space-y-2.5">
          {
            [
              { label: "Inicio", href: "/" },
              { label: "Nosotros", href: "/about" },
              { label: "Contacto", href: "/contact" },
              { label: "Aviso de Privacidad", href: "#" },
            ].map((l) => (
              <li>
                <a
                  href={l.href}
                  class="text-sm text-white/60 hover:text-white transition-colors duration-200 flex items-center gap-2"
                >
                  <span class="w-1 h-1 rounded-full bg-accent shrink-0" />
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contact column -->
      <div>
        <h3
          class="text-sm font-semibold uppercase tracking-widest text-accent mb-5"
        >
          Contacto
        </h3>
        <ul class="space-y-4 text-sm text-white/60">
          <li class="flex items-start gap-3">
            <svg
              class="w-4 h-4 mt-0.5 shrink-0 text-accent"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              ></path><path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg
            >
            <span>Rio Papaloapan #308, Col. Mexico, Monterrey, N.L CP64710</span
            >
          </li>
          <li class="flex items-center gap-3">
            <svg
              class="w-4 h-4 shrink-0 text-accent"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path></svg
            >
            <a
              href="tel:+528183652769"
              class="hover:text-white transition-colors inline-flex items-center gap-1"
              aria-label="Llamar a Hard-Ware"
              >Llamar ahora</a
            >
          </li>
          <li class="flex items-center gap-3">
            <svg
              class="w-4 h-4 shrink-0 text-accent"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path></svg
            >
            <a
              href="mailto:ventas.online@hard-ware.com.mx"
              target="_blank"
              class="hover:text-white transition-colors break-all"
              >ventas.online@hard-ware.com.mx</a
            >
          </li>
          <li class="flex items-center gap-3">
            <svg
              class="w-4 h-4 shrink-0 text-accent"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg
            >
            <span>Lun – Vie: 8:00 am – 6:00 pm</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="mt-14 pt-8 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-4"
    >
      <p class="text-xs text-white/40">
        &copy; {year} Hard-Ware. Todos los derechos reservados.
      </p>
      <p class="text-xs text-white/40">Monterrey, Nuevo León, México</p>
    </div>
  </div>
</footer>
