---
// Navbar.astro — sticky, transparent → solid on scroll, with mobile hamburger
import ThemeToggle from "./shared/ThemeToggle.astro";
import CartButton from "./cart/CartButton";

const navLinks = [
  // { label: "Inicio", href: "/" },
  { label: "Productos", href: "/productos" },
  { label: "Blogs", href: "/blogs" },
  { label: "Nosotros", href: "/about" },
  { label: "Contacto", href: "/contact" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) => {
  if (href === "/") return currentPath === "/";
  return currentPath === href || currentPath.startsWith(`${href}/`);
};
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
>
  <div class="container-lg">
    <nav class="flex items-center justify-between h-18 md:h-20">
      <!-- Logo -->
      <a
        href="/"
        class="flex items-center gap-2 group"
        aria-label="Hard-Ware Home"
      >
        <span
          class="flex items-center justify-center w-9 h-9 rounded-lg bg-accent text-primary font-bold text-lg leading-none select-none"
        >
          H·W
        </span>
        <span
          id="nav-logo-text"
          class="nav-link text-xl font-extrabold tracking-tight transition-colors duration-300"
        >
          Hard<span class="text-accent">-</span>Ware
        </span>
      </a>

      <!-- Desktop links -->
      <ul class="hidden md:flex items-center gap-8 list-none m-0 p-0">
        {
          navLinks.map((link) => {
            const active = isActive(link.href);
            return (
              <li>
                <a
                  href={link.href}
                  data-active={active ? "true" : "false"}
                  aria-current={active ? "page" : undefined}
                  class="nav-link text-sm font-medium tracking-wide transition-colors duration-200 relative group"
                >
                  {link.label}
                  <span class="nav-underline absolute -bottom-0.5 left-0 h-px bg-accent transition-all duration-300" />
                </a>
              </li>
            );
          })
        }
      </ul>

      <!-- Right actions -->
      <div class="hidden md:flex items-center gap-3">
        <ThemeToggle />
        <CartButton client:load />
        <a
          href="/contact"
          class="inline-flex items-center gap-2 px-5 py-2 text-xs font-semibold uppercase tracking-widest rounded-full bg-accent text-primary hover:bg-amber-400 transition-colors duration-300"
        >
          Cotizar
        </a>
      </div>

      <!-- Mobile actions: cart + hamburger -->
      <div class="flex md:hidden items-center gap-1">
        <CartButton client:load />
        <button
          id="mobile-menu-btn"
          aria-label="Abrir menú"
          aria-expanded="false"
          class="flex flex-col gap-1.5 p-2 rounded-md"
        >
          <span
            class="hamburger-bar block h-0.5 w-6 rounded transition-all duration-300"
            style="background: currentColor"></span>
          <span
            class="hamburger-bar block h-0.5 w-6 rounded transition-all duration-300"
            style="background: currentColor"></span>
          <span
            class="hamburger-bar block h-0.5 w-4 rounded transition-all duration-300"
            style="background: currentColor"></span>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    class="md:hidden max-h-0 overflow-hidden transition-all duration-500 ease-in-out bg-primary/95 backdrop-blur-md border-t border-white/10"
  >
    <div class="container-lg py-6 flex flex-col gap-4">
      {
        navLinks.map((link) => {
          const active = isActive(link.href);
          return (
            <a
              href={link.href}
              data-active={active ? "true" : "false"}
              aria-current={active ? "page" : undefined}
              class:list={[
                "mobile-link text-base font-medium transition-colors py-1 border-b border-white/10 last:border-0",
                active ? "text-accent" : "text-white/80 hover:text-white",
              ]}
            >
              {link.label}
            </a>
          );
        })
      }
      <div class="flex items-center gap-3 pt-2">
        <ThemeToggle />
        <a
          href="/contact"
          class="inline-flex items-center px-5 py-2 text-xs font-semibold uppercase tracking-widest rounded-full bg-accent text-primary hover:bg-amber-400 transition-colors"
        >
          Cotizar
        </a>
      </div>
    </div>
  </div>
</header>

<!-- Spacer to push content below fixed navbar -->
<div class="h-18 md:h-20 pointer-events-none" aria-hidden="true"></div>

<style>
  #navbar {
    background: transparent;
    --nav-theme-color: var(--color-primary);
    --nav-theme-border: rgba(1, 51, 131, 0.35);
    --nav-theme-hover-bg: rgba(1, 51, 131, 0.08);
    --nav-theme-hover-border: var(--color-primary);
    --nav-cart-color: var(--color-primary);
    --nav-cart-hover-bg: rgba(1, 51, 131, 0.08);
  }

  #navbar :global(.cart-btn) {
    color: var(--nav-cart-color);
  }
  #navbar :global(.cart-btn:hover) {
    background-color: var(--nav-cart-hover-bg);
  }

  /* Ensure the theme toggle inside the blue mobile menu panel is always white in light mode */
  #mobile-menu {
    --nav-theme-color: #ffffff;
    --nav-theme-border: rgba(255, 255, 255, 0.35);
    --nav-theme-hover-bg: rgba(255, 255, 255, 0.12);
    --nav-theme-hover-border: rgba(255, 255, 255, 0.6);
  }

  /* Nav link color – default (light mode, transparent) */
  #navbar .nav-link {
    color: var(--color-ink);
  }
  #navbar .nav-link:hover {
    color: var(--color-primary);
  }

  /* When solid (scrolled or not-home): always white text */
  #navbar.scrolled .nav-link,
  #navbar.always-solid .nav-link {
    color: rgba(255, 255, 255, 0.85);
  }
  #navbar.scrolled .nav-link:hover,
  #navbar.always-solid .nav-link:hover {
    color: #ffffff;
  }

  /* Dark mode transparent: also use white text */
  .dark #navbar .nav-link {
    color: rgba(255, 255, 255, 0.8);
  }
  .dark #navbar .nav-link:hover {
    color: #ffffff;
  }

  /* Active link — accent color + full underline, in every navbar state */
  #navbar .nav-link[data-active="true"],
  #navbar.scrolled .nav-link[data-active="true"],
  #navbar.always-solid .nav-link[data-active="true"],
  .dark #navbar .nav-link[data-active="true"] {
    color: var(--color-accent);
  }

  /* Underline: hidden by default, full-width on hover OR when active */
  #navbar .nav-underline {
    width: 0;
  }
  #navbar .nav-link:hover .nav-underline,
  #navbar .nav-link[data-active="true"] .nav-underline {
    width: 100%;
  }

  /* Hamburger color */
  #navbar #mobile-menu-btn {
    color: var(--color-ink);
  }
  #navbar.scrolled #mobile-menu-btn,
  #navbar.always-solid #mobile-menu-btn,
  .dark #navbar #mobile-menu-btn {
    color: #ffffff;
  }

  /* Scrolled state */
  #navbar.scrolled {
    background: rgba(1, 51, 131, 0.95);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.25);
    --nav-theme-color: #ffffff;
    --nav-theme-border: rgba(255, 255, 255, 0.35);
    --nav-theme-hover-bg: rgba(255, 255, 255, 0.12);
    --nav-theme-hover-border: rgba(255, 255, 255, 0.6);
    --nav-cart-color: var(--color-accent);
    --nav-cart-hover-bg: rgba(255, 255, 255, 0.1);
  }

  /* Always solid (non-home pages) */
  #navbar.always-solid {
    background: rgba(1, 51, 131, 0.98);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    --nav-theme-color: #ffffff;
    --nav-theme-border: rgba(255, 255, 255, 0.35);
    --nav-theme-hover-bg: rgba(255, 255, 255, 0.12);
    --nav-theme-hover-border: rgba(255, 255, 255, 0.6);
    --nav-cart-color: var(--color-accent);
    --nav-cart-hover-bg: rgba(255, 255, 255, 0.1);
  }

  /* Dark mode overrides for navbar variables */
  .dark #navbar,
  .dark #navbar.scrolled,
  .dark #navbar.always-solid {
    --nav-theme-color: var(--color-accent);
    --nav-theme-border: rgba(250, 183, 2, 0.45);
    --nav-theme-hover-bg: rgba(250, 183, 2, 0.1);
    --nav-theme-hover-border: var(--color-accent);
    --nav-cart-color: #ffffff;
    --nav-cart-hover-bg: rgba(255, 255, 255, 0.1);
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const navbar = document.getElementById("navbar");
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    if (!navbar) return;

    // Detect if we're on the home page
    const isHome =
      window.location.pathname === "/" || window.location.pathname === "";
    if (!isHome) {
      navbar.classList.add("always-solid");
    } else {
      navbar.classList.remove("always-solid");
    }

    // Scroll handler
    function onScroll() {
      if (isHome) {
        if (window.scrollY > 60) {
          navbar!.classList.add("scrolled");
        } else {
          navbar!.classList.remove("scrolled");
        }
      }
    }
    window.removeEventListener("scroll", onScroll);
    window.addEventListener("scroll", onScroll);
    onScroll();

    // Mobile menu toggle
    if (btn && menu) {
      btn.addEventListener("click", () => {
        const open = btn.getAttribute("aria-expanded") === "true";
        btn.setAttribute("aria-expanded", String(!open));
        menu.style.maxHeight = open ? "0" : `${menu.scrollHeight}px`;
        const bars = btn.querySelectorAll(".hamburger-bar");
        bars[0].classList.toggle("rotate-45", !open);
        bars[0].classList.toggle("translate-y-2", !open);
        bars[1].classList.toggle("opacity-0", !open);
        bars[2].classList.toggle("-rotate-45", !open);
        bars[2].classList.toggle("-translate-y-2", !open);
        bars[2].classList.toggle("w-6", !open);
      });

      // Close on link click
      menu.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          btn.setAttribute("aria-expanded", "false");
          menu.style.maxHeight = "0";
        });
      });
    }
  });
</script>
