---
import { getCollection } from "astro:content";

interface Props {
  limit?: number;
  featuredSlugs?: string[];
}

const { limit = 8, featuredSlugs } = Astro.props as Props;

const all = await getCollection("marcas");

const ordered = featuredSlugs
  ? featuredSlugs
      .map((s) => all.find((m) => m.id === s))
      .filter((m): m is NonNullable<typeof m> => Boolean(m))
  : all;

const marcas = ordered.slice(0, limit);
---

<section
  id="marcas"
  class="section-padding bg-slate-50 dark:bg-blue-900/20 transition-colors duration-500"
>
  <div class="container-lg">
    <div class="text-center mb-14">
      <span
        class="inline-block px-4 py-1.5 text-xs font-semibold uppercase tracking-widest rounded-full mb-4 text-primary bg-primary/10 dark:bg-primary/5 dark:text-accent"
      >
        Marcas que representamos
      </span>
      <h2
        class="text-4xl font-extrabold dark:text-white text-black mb-4 leading-tight"
      >
        Distribuidor <span class="text-gradient">autorizado en México</span>
      </h2>
      <p class="text-muted max-w-xl mx-auto text-base leading-relaxed">
        Alianzas directas con los fabricantes líderes en tecnología industrial,
        impresión, identificación y automatización. SEW Eurodrive disponible
        vía nuestra alianza con MG Industrial Imports.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {
        marcas.map((marca) => (
          <a
            href={`/marcas/${marca.id}`}
            class="bento-card group flex flex-col items-center text-center gap-3 py-8 hover:border-primary dark:hover:border-accent transition-colors relative"
            aria-label={`Ver productos de ${marca.data.nombre}`}
          >
            {marca.data.distribuidorAutorizadoMX && (
              <span
                class="absolute top-2 right-2 w-4 h-4 rounded-full flex items-center justify-center text-[8px] font-bold text-primary"
                style="background: #fab702;"
                title="Distribuidor Autorizado MX"
              >
                ✓
              </span>
            )}
            <div
              class="w-14 h-14 rounded-2xl flex items-center justify-center font-bold text-sm tracking-widest transition-transform duration-300 group-hover:scale-110"
              style="background: var(--color-primary); color: var(--color-accent);"
            >
              {marca.data.nombre.slice(0, 3).toUpperCase()}
            </div>
            <div>
              <p class="font-semibold text-sm text-black dark:text-white leading-tight group-hover:text-primary dark:group-hover:text-accent transition-colors">
                {marca.data.nombre}
              </p>
              {marca.data.categorias[0] && (
                <p class="text-xs text-muted mt-0.5">
                  {marca.data.categorias[0]}
                </p>
              )}
            </div>
          </a>
        ))
      }
    </div>

    <div class="mt-10 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-muted text-sm">
        ¿Tu marca no aparece?{" "}
        <strong class="text-black dark:text-white">
          Pregúntanos por disponibilidad.
        </strong>
      </p>
      <a
        href="/marcas"
        class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full text-xs font-bold uppercase tracking-widest text-primary hover:-translate-y-0.5 hover:shadow-md transition-all duration-300"
        style="background: #fab702;"
      >
        Ver todas las marcas
        <svg
          class="w-3.5 h-3.5"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
