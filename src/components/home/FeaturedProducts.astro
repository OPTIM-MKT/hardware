---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const all = await getCollection("productos");
const featured = all
  .filter((p) => p.data.destacado || p.data.nuevo)
  .sort((a, b) => Number(b.data.destacado) - Number(a.data.destacado))
  .slice(0, 6);
---

<section class="section-padding bg-slate-50 dark:bg-slate-950">
  <div class="container-lg">
    <div
      class="flex flex-col md:flex-row items-start md:items-end justify-between mb-10 gap-4"
    >
      <div>
        <span
          class="inline-block px-3 py-1 text-[10px] font-semibold uppercase tracking-widest rounded-full mb-3"
          style="background: rgba(250,183,2,0.12); color: #fab702;"
        >
          Catálogo
        </span>
        <h2
          class="text-3xl md:text-4xl font-extrabold text-primary dark:text-white mb-2 leading-tight"
        >
          Productos destacados
        </h2>
        <p class="text-muted text-base leading-relaxed max-w-md">
          Selección de equipos más solicitados en industria, retail y
          operaciones.
        </p>
      </div>
      <a
        href="/productos"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-full font-semibold text-sm tracking-wide border border-line text-primary dark:text-white hover:border-primary hover:text-primary transition-colors duration-300"
      >
        Ver catálogo completo
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {
        featured.map((p) => (
          <a
            href={`/productos/${p.id}`}
            class="group bento-card flex flex-col gap-4 p-5 hover:border-primary/30 transition-all"
          >
            <div class="aspect-[4/3] rounded-xl overflow-hidden bg-line relative">
              {p.data.imagen && (
                <Image
                  src={p.data.imagen}
                  alt={p.data.nombre}
                  inferSize={true}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              )}
              {p.data.nuevo && (
                <span class="absolute top-3 left-3 text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-full bg-accent text-primary">
                  Nuevo
                </span>
              )}
            </div>
            <p class="text-[10px] font-semibold uppercase tracking-widest text-muted">
              {p.data.marca} · {p.data.categoria}
            </p>
            <h3 class="text-base font-bold text-primary dark:text-white line-clamp-2 group-hover:text-primary transition-colors">
              {p.data.nombre}
            </h3>
            <p class="text-sm text-muted line-clamp-2">{p.data.descripcion}</p>
          </a>
        ))
      }
    </div>
  </div>
</section>
