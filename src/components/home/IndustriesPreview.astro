---
import { getCollection } from "astro:content";
import FeatureCard from "../shared/FeatureCard";

interface Props {
  limit?: number;
  featuredSlugs?: string[];
}

const { limit = 8, featuredSlugs } = Astro.props as Props;

const all = await getCollection("industrias");
const ordered = featuredSlugs
  ? featuredSlugs
      .map((s) => all.find((i) => i.id === s))
      .filter((i): i is NonNullable<typeof i> => Boolean(i))
  : all;
const industrias = ordered.slice(0, limit);

const PLACEHOLDER =
  "https://images.unsplash.com/photo-1516937941344-00b4e0337589?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D";
---

<section class="section-padding">
  <div class="container-lg">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
      <div class="max-w-xl">
        <span
          class="inline-block px-3 py-1 text-[10px] font-bold uppercase tracking-widest rounded-full mb-3"
          style="background: rgba(250,183,2,0.12); color: #fab702;"
        >
          Industrias
        </span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-ink leading-tight">
          Tecnología para cada sector
        </h2>
        <p class="text-muted text-sm mt-3 leading-relaxed">
          Diseñamos soluciones específicas según los retos operativos de cada
          industria.
        </p>
      </div>
      <a
        href="/industrias"
        class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-primary dark:text-accent hover:gap-3 transition-all w-fit"
      >
        Ver todas las industrias
        <svg
          class="w-3.5 h-3.5"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
      {
        industrias.map((i) => (
          <FeatureCard
            imagen={i.data.imagen ?? PLACEHOLDER}
            titulo={i.data.nombre}
            descripcion={i.data.descripcion}
            href={`/industrias/${i.id}`}
            ctaLabel="Ver"
          />
        ))
      }
    </div>
  </div>
</section>
