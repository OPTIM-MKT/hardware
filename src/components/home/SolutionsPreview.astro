---
import { getCollection } from "astro:content";
import FeatureCard from "../shared/FeatureCard";

interface Props {
  limit?: number;
  onlyDestacadas?: boolean;
}

const { limit = 6, onlyDestacadas = false } = Astro.props as Props;

const all = await getCollection("soluciones");
const filtered = onlyDestacadas ? all.filter((s) => s.data.destacada) : all;
const soluciones = filtered.slice(0, limit);

const PLACEHOLDER =
  "https://images.unsplash.com/photo-1516937941344-00b4e0337589?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D";
---

<section class="section-padding bg-slate-50 dark:bg-blue-900/10">
  <div class="container-lg">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
      <div class="max-w-xl">
        <span
          class="inline-block px-3 py-1 text-[10px] font-bold uppercase tracking-widest rounded-full mb-3"
          style="background: rgba(250,183,2,0.12); color: #fab702;"
        >
          Soluciones
        </span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-ink leading-tight">
          No vendemos productos. Entregamos soluciones.
        </h2>
        <p class="text-muted text-sm mt-3 leading-relaxed">
          HardWare es distribuidor autorizado en México. Integramos hardware,
          software y servicio para resolver problemas reales de operación.
        </p>
      </div>
      <a
        href="/soluciones"
        class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-primary dark:text-accent hover:gap-3 transition-all w-fit"
      >
        Ver todas las soluciones
        <svg
          class="w-3.5 h-3.5"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        soluciones.map((s) => (
          <FeatureCard
            imagen={s.data.imagen ?? PLACEHOLDER}
            titulo={s.data.titulo ?? s.data.nombre}
            descripcion={s.data.descripcion}
            href={`/soluciones/${s.id}`}
            eyebrow={s.data.tagline}
            ctaLabel={s.data.ctaLabel ?? "Ver solución"}
          />
        ))
      }
    </div>
  </div>
</section>
