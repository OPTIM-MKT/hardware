---
/**
 * LogoC.astro — Reusable brand logotype component.
 *
 * Renders the full HW logotype (text + icon) inside a rounded container
 * with a subtle background so the white artwork stays visible on any surface.
 *
 * @prop {string}  class – Extra Tailwind classes forwarded to the outer <a>.
 */
import { Image } from "astro:assets";
import Logo from "@/assets/HW.webp";

interface Props {
  /** Additional Tailwind classes on the root anchor */
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<a
  href="/"
  class:list={[
    "logo-c inline-flex cursor-pointer items-center justify-center rounded-2xl bg-primary dark:bg-white/10 p-2 transition-all duration-300 hover:bg-primary/80 hover:shadow-[0_0_0_2px_rgba(250,183,2,0.35)] dark:hover:bg-white/20",
    className,
  ]}
  aria-label="Hard-Ware — Ir al inicio"
>
  <Image
    src={Logo}
    alt="Hard-Ware Logo"
    widths={[120, 160]}
    sizes="120px"
    class="h-8 w-auto object-contain"
    loading="eager"
  />
</a>
