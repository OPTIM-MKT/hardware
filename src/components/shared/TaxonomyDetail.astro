---
import { getCollection } from "astro:content";
import ContactForm from "../contact/ContactForm";
import FeatureCard from "./FeatureCard";

interface Props {
  kind: "industria" | "solucion";
  data: {
    nombre: string;
    titulo?: string;
    descripcion: string;
    imagen?: string;
    retosComunes: string[];
    solucionesRecomendadas: string[];
    productosRelevantes: string[];
    marcasRelacionadas: string[];
  };
  slug: string;
}

const { kind, data, slug } = Astro.props as Props;

const labelKind = kind === "industria" ? "Industria" : "Solución";
const counterpartLabel = kind === "industria" ? "Soluciones recomendadas" : "Industrias relacionadas";
const counterpartCollection = kind === "industria" ? "soluciones" : "industrias";

const [marcasAll, productosAll, solucionesAll, industriasAll] = await Promise.all([
  getCollection("marcas"),
  getCollection("productos"),
  getCollection("soluciones"),
  getCollection("industrias"),
]);

const counterpartAll = kind === "industria" ? solucionesAll : industriasAll;
const counterpartSlugs = data.solucionesRecomendadas;

const counterpartItems = counterpartSlugs
  .map((s) => counterpartAll.find((e) => e.id === s))
  .filter((e): e is NonNullable<typeof e> => Boolean(e));

const productos = data.productosRelevantes
  .map((s) => productosAll.find((e) => e.id === s))
  .filter((e): e is NonNullable<typeof e> => Boolean(e));

const marcas = data.marcasRelacionadas
  .map((s) => marcasAll.find((e) => e.id === s))
  .filter((e): e is NonNullable<typeof e> => Boolean(e));

const heroImage =
  data.imagen ??
  "https://images.unsplash.com/photo-1516937941344-00b4e0337589?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D";

const title = data.titulo ?? data.nombre;
const productOptions = productos.map((p) => ({
  value: p.id,
  label: p.data.nombre,
}));
---

<!-- Hero -->
<section class="relative overflow-hidden">
  <img
    src={heroImage}
    alt={title}
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
    decoding="async"
  />
  <div
    class="absolute inset-0"
    style="background: linear-gradient(120deg, rgba(1,51,131,0.92) 0%, rgba(35,48,96,0.78) 60%, rgba(1,51,131,0.55) 100%);"
  >
  </div>

  <div class="relative z-10 container-lg section-padding">
    <nav
      aria-label="Breadcrumb"
      class="flex items-center gap-2 text-xs text-white/60 mb-8"
    >
      <a href="/" class="hover:text-white transition-colors">Inicio</a>
      <span>/</span>
      <a
        href={kind === "industria" ? "/industrias" : "/soluciones"}
        class="hover:text-white transition-colors"
      >
        {kind === "industria" ? "Industrias" : "Soluciones"}
      </a>
      <span>/</span>
      <span class="text-white/85">{data.nombre}</span>
    </nav>

    <span
      class="inline-block px-3 py-1 text-[10px] font-bold uppercase tracking-widest rounded-full mb-4"
      style="background: rgba(250,183,2,0.18); color: #fab702;"
    >
      {labelKind}
    </span>

    <h1
      class="text-4xl md:text-5xl font-extrabold text-white leading-tight max-w-3xl mb-5"
    >
      {title}
    </h1>
    <p class="text-white/75 text-base md:text-lg leading-relaxed max-w-2xl">
      {data.descripcion}
    </p>

    <div class="mt-6 inline-flex items-center gap-2">
      <span
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-bold uppercase tracking-widest text-primary"
        style="background: #fab702;"
      >
        ✓ HardWare es distribuidor autorizado en México
      </span>
    </div>
  </div>
</section>

<!-- Contenido Markdown -->
<section class="section-padding pb-0">
  <div class="container-lg">
    <article class="prose dark:prose-invert prose-lg max-w-4xl prose-headings:font-extrabold prose-a:text-primary dark:prose-a:text-accent prose-img:rounded-2xl prose-headings:text-ink">
      <slot />
    </article>
  </div>
</section>

<!-- Retos comunes -->
{
  data.retosComunes.length > 0 && (
    <section class="section-padding">
      <div class="container-lg">
        <div class="mb-10 max-w-2xl">
          <span
            class="inline-block px-3 py-1 text-[10px] font-bold uppercase tracking-widest rounded-full mb-3"
            style="background: rgba(250,183,2,0.12); color: #fab702;"
          >
            Retos comunes
          </span>
          <h2 class="text-3xl font-extrabold text-ink leading-tight">
            Lo que vemos todos los días en {data.nombre.toLowerCase()}
          </h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {data.retosComunes.map((reto, i) => (
            <article class="bento-card flex items-start gap-4">
              <span
                class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 font-extrabold text-sm"
                style="background: rgba(250,183,2,0.15); color: #fab702;"
              >
                {String(i + 1).padStart(2, "0")}
              </span>
              <p class="text-ink text-sm leading-relaxed">{reto}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}

<!-- Soluciones / Industrias relacionadas -->
{
  counterpartItems.length > 0 && (
    <section class="section-padding bg-slate-50 dark:bg-blue-900/10">
      <div class="container-lg">
        <div class="mb-10 max-w-2xl">
          <span
            class="inline-block px-3 py-1 text-[10px] font-bold uppercase tracking-widest rounded-full mb-3"
            style="background: rgba(250,183,2,0.12); color: #fab702;"
          >
            {counterpartLabel}
          </span>
          <h2 class="text-3xl font-extrabold text-ink leading-tight">
            {kind === "industria"
              ? `Cómo resolvemos los retos de ${data.nombre}`
              : `Industrias donde aplica ${data.nombre}`}
          </h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {counterpartItems.map((item) => (
            <FeatureCard
              imagen={
                item.data.imagen ??
                "https://images.unsplash.com/photo-1516937941344-00b4e0337589?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
              }
              titulo={item.data.titulo ?? item.data.nombre}
              descripcion={item.data.descripcion}
              href={`/${counterpartCollection}/${item.id}`}
              eyebrow={kind === "industria" ? "Solución" : "Industria"}
              ctaLabel={kind === "industria" ? "Ver solución" : "Ver industria"}
            />
          ))}
        </div>
      </div>
    </section>
  )
}

<!-- Productos relevantes -->
{
  productos.length > 0 && (
    <section class="section-padding">
      <div class="container-lg">
        <div class="mb-10 max-w-2xl">
          <span
            class="inline-block px-3 py-1 text-[10px] font-bold uppercase tracking-widest rounded-full mb-3"
            style="background: rgba(250,183,2,0.12); color: #fab702;"
          >
            Productos
          </span>
          <h2 class="text-3xl font-extrabold text-ink leading-tight">
            Equipamiento recomendado
          </h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {productos.map((p) => (
            <FeatureCard
              imagen={
                p.data.imagen ??
                "https://images.unsplash.com/photo-1516937941344-00b4e0337589?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
              }
              titulo={p.data.nombre}
              descripcion={p.data.descripcion}
              href={`#cotizar`}
              eyebrow={p.data.categoria ?? "Producto"}
              ctaLabel="Cotizar producto"
            />
          ))}
        </div>
      </div>
    </section>
  )
}

<!-- Marcas relacionadas -->
{
  marcas.length > 0 && (
    <section class="section-padding bg-slate-50 dark:bg-blue-900/10">
      <div class="container-lg">
        <div class="mb-10 max-w-2xl">
          <span
            class="inline-block px-3 py-1 text-[10px] font-bold uppercase tracking-widest rounded-full mb-3"
            style="background: rgba(250,183,2,0.12); color: #fab702;"
          >
            Marcas asociadas
          </span>
          <h2 class="text-3xl font-extrabold text-ink leading-tight">
            Distribuimos las marcas líderes para esta {kind}
          </h2>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
          {marcas.map((m) => (
            <a
              href={`/marcas/${m.id}`}
              class="bento-card group flex flex-col items-center text-center gap-3 py-8 hover:border-primary dark:hover:border-accent transition-colors"
            >
              <div
                class="w-14 h-14 rounded-2xl flex items-center justify-center font-bold text-sm tracking-widest transition-transform duration-300 group-hover:scale-110"
                style="background: var(--color-primary); color: var(--color-accent);"
              >
                {m.data.nombre.slice(0, 3).toUpperCase()}
              </div>
              <p class="font-semibold text-sm text-ink leading-tight group-hover:text-primary dark:group-hover:text-accent transition-colors">
                {m.data.nombre}
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )
}

<!-- CTA + ContactForm -->
<section class="section-padding" id="cotizar">
  <div class="container-lg">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <div class="flex flex-col gap-5">
        <span
          class="inline-block px-3 py-1 text-[10px] font-bold uppercase tracking-widest rounded-full w-fit"
          style="background: rgba(250,183,2,0.12); color: #fab702;"
        >
          HardWare es distribuidor autorizado en México
        </span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-ink leading-tight">
          Diseñamos la solución para {data.nombre.toLowerCase()}
        </h2>
        <p class="text-muted text-base leading-relaxed">
          Habla con un especialista. Diseñamos el equipamiento, integración y
          consumibles a la medida de tu operación, con respaldo de fábrica y
          atención personalizada.
        </p>
        <ul class="space-y-3 mt-2">
          {
            [
              "Asesoría técnica especializada",
              "Conexión directa con fabricantes",
              "Capacidad para pedidos a gran escala",
              "Atención personalizada en menos de 24 h",
            ].map((item) => (
              <li class="flex items-center gap-3 text-sm text-ink">
                <span
                  class="w-5 h-5 rounded-full flex items-center justify-center shrink-0 text-primary text-xs font-bold"
                  style="background: rgba(250,183,2,0.2);"
                >
                  ✓
                </span>
                {item}
              </li>
            ))
          }
        </ul>
      </div>
      <ContactForm
        client:visible
        productOptions={productOptions.length > 0 ? productOptions : undefined}
        defaultProduct={productOptions[0]?.value ?? slug}
        title={`Solicitar propuesta · ${data.nombre}`}
        subtitle="Cuéntanos los detalles. Te respondemos en menos de 24 h hábiles."
        submitLabel="Solicitar propuesta"
      />
    </div>
  </div>
</section>
