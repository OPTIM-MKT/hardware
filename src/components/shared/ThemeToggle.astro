---
// ThemeToggle.astro — adapts to both light/dark and transparent/solid Navbar contexts
---

<button
  data-theme-toggle
  aria-label="Toggle color theme"
  class="theme-toggle-btn inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold uppercase tracking-widest rounded-full border transition-all duration-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent"
>
  <!-- Moon icon (shown in light mode) -->
  <svg
    class="block dark:hidden w-4 h-4 shrink-0"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    viewBox="0 0 24 24"
    aria-hidden="true"
  >
    <path stroke-linecap="round" stroke-linejoin="round"
      d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
  </svg>
  <!-- Sun icon (shown in dark mode) -->
  <svg
    class="hidden dark:block w-4 h-4 shrink-0"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    viewBox="0 0 24 24"
    aria-hidden="true"
  >
    <path stroke-linecap="round" stroke-linejoin="round"
      d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
  </svg>
  <span data-theme-label class="hidden md:inline">Dark</span>
</button>

<style>
  /*
    Light mode → white text + white-ish border (works on solid blue navbar,
    transparent navbar on home is also against a colored hero).
  */
  .theme-toggle-btn {
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.35);
    background: transparent;
  }
  .theme-toggle-btn:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.6);
  }

  /*
    Dark mode → accent color (yellow), accent border
  */
  .dark .theme-toggle-btn {
    color: var(--color-accent);
    border-color: rgba(250, 183, 2, 0.45);
  }
  .dark .theme-toggle-btn:hover {
    background: rgba(250, 183, 2, 0.1);
    border-color: var(--color-accent);
  }
</style>
