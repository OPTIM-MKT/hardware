---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { SEO } from "astro-seo";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ScrollTop from "../components/shared/ScrollTop.astro";
import CartPanel from "../components/cart/CartPanel";
import AppToaster from "../components/shared/AppToaster";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  /** Override the canonical URL when needed (e.g. paginated pages) */
  canonical?: string;
}

const SITE_NAME = "Hard-Ware";
const SITE_URL = "https://www.hard-ware.com.mx";

const {
  title = "Hard-Ware | Distribuidor autorizado · Tecnología, impresión, identificación y automatización",
  description = "HardWare es distribuidor autorizado en México de equipos industriales: impresión, identificación automática, captura de datos, equipos rugged y automatización. Monterrey, N.L.",
  image = "/HWLogo.webp",
  canonical,
} = Astro.props;

const currentPath = Astro.url.pathname;
const canonicalURL = canonical ?? new URL(currentPath, SITE_URL).href;
const absoluteImage = image.startsWith("http")
  ? image
  : new URL(image, SITE_URL).href;

const isHome = currentPath === "/" || currentPath === "";

const localBusinessLD = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Hard-Ware",
  description:
    "Distribuidor autorizado en México de soluciones industriales: impresión, identificación automática, captura de datos, equipos rugged y automatización.",
  url: SITE_URL,
  logo: `${SITE_URL}/HWLogo.webp`,
  image: `${SITE_URL}/HWLogo.webp`,
  telephone: "+528183652769",
  email: "ventas.online@hard-ware.com.mx",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Rio Papaloapan #308, Col. Mexico",
    addressLocality: "Monterrey",
    addressRegion: "Nuevo León",
    postalCode: "64710",
    addressCountry: "MX",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 25.6866,
    longitude: -100.3161,
  },
  openingHoursSpecification: {
    "@type": "OpeningHoursSpecification",
    dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    opens: "08:00",
    closes: "18:00",
  },
  sameAs: ["https://wa.me/528183652769"],
};

const webSiteLD = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE_NAME,
  url: SITE_URL,
  inLanguage: "es-MX",
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/x-icon" href="/icon.ico" />
    <ClientRouter />
    <meta name="generator" content={Astro.generator} />

    {/* Google Tag Manager — colocado lo más arriba posible en <head> */}
    <script is:inline>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-WC9PWCK6");
    </script>

    {/* Canonical */}
    <link rel="canonical" href={canonicalURL} />

    {/* Google Fonts — async load to avoid render-blocking */}
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=Syne:wght@700;800&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=Syne:wght@700;800&display=swap"
      media="print"
      onload="this.media='all'"
    />

    <SEO
      title={title}
      description={description}
      openGraph={{
        basic: {
          title,
          type: "website",
          image: absoluteImage,
          url: canonicalURL,
        },
        optional: {
          description,
          siteName: SITE_NAME,
          locale: "es_MX",
        },
        image: {
          alt: "Hard-Ware — Soluciones Tecnológicas Industriales",
          width: 1200,
          height: 630,
          type: "image/webp",
        },
      }}
      twitter={{
        card: "summary_large_image",
        title,
        description,
        image: absoluteImage,
      }}
      extend={{
        meta: [
          { name: "theme-color", content: "#013383" },
          { name: "author", content: "Hard-Ware" },
          {
            name: "keywords",
            content:
              "distribuidor autorizado méxico, impresión industrial, identificación automática, captura de datos, equipos rugged, automatización, Monterrey, mantenimiento industrial, reparación equipos, Zebra, Honeywell, Datalogic",
          },
          { property: "og:locale", content: "es_MX" },
        ],
        link: [],
      }}
    />

    {/* JSON-LD structured data — only on the home page */}
    {
      isHome && (
        <>
          <script
            type="application/ld+json"
            set:html={JSON.stringify(localBusinessLD)}
          />
          <script
            type="application/ld+json"
            set:html={JSON.stringify(webSiteLD)}
          />
        </>
      )
    }

    <!-- Dark mode init: runs before paint to avoid flash + persists across View Transitions -->
    <script is:inline>
      (function () {
        function applyTheme() {
          const stored = localStorage.getItem("theme");
          const prefersDark = window.matchMedia(
            "(prefers-color-scheme: dark)",
          ).matches;
          const isDark = stored === "dark" || (!stored && prefersDark);
          document.documentElement.classList.toggle("dark", isDark);
        }
        applyTheme();
        // ClientRouter swaps <head>/<body>; the html.dark class can be lost.
        // Reapply *before* paint of the new page so there's no flash.
        document.addEventListener("astro:before-swap", (e) => {
          const stored = localStorage.getItem("theme");
          const prefersDark = window.matchMedia(
            "(prefers-color-scheme: dark)",
          ).matches;
          const isDark = stored === "dark" || (!stored && prefersDark);
          /** @type {Document} */
          const newDoc = e.newDocument;
          newDoc.documentElement.classList.toggle("dark", isDark);
        });
        document.addEventListener("astro:after-swap", applyTheme);
      })();
    </script>
  </head>

  <body class="bg-canvas text-ink antialiased">
    {/* Google Tag Manager (noscript) — primera línea dentro de <body> */}
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-WC9PWCK6"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe>
    </noscript>

    <Navbar />

    <main>
      <slot />
    </main>

    <Footer />
    <ScrollTop />
    <CartPanel client:idle />
    <AppToaster client:idle />

    <!-- Theme toggle logic -->
    <script>
      function initThemeToggle() {
        const btn = document.querySelector("[data-theme-toggle]");
        const label = document.querySelector("[data-theme-label]");
        if (!btn) return;

        function updateLabel() {
          const isDark = document.documentElement.classList.contains("dark");
          if (label) label.textContent = isDark ? "Light" : "Dark";
        }

        btn.addEventListener("click", () => {
          document.documentElement.classList.toggle("dark");
          const isDark = document.documentElement.classList.contains("dark");
          localStorage.setItem("theme", isDark ? "dark" : "light");
          updateLabel();
        });

        updateLabel();
      }

      document.addEventListener("astro:page-load", initThemeToggle);
    </script>
  </body>
</html>
