---
import Layout from "../layouts/Layout.astro";
import AboutBento from "../components/about/AboutBento";
import ValueProposition from "../components/about/ValueProposition";
---

<Layout
  title="Sobre Nosotros | Hard-Ware – Alianzas y Capacitación"
  description="Conoce la historia, misión, valores y equipo detrás de Hard-Ware, tu aliado en mantenimiento industrial en Monterrey."
>
  <!-- Page hero bar -->
  <div
    class="w-full py-16 md:py-24 text-white"
    style="background: linear-gradient(135deg, #013383 0%, #233060 100%);"
  >
    <div class="container-lg text-center">
      <p
        class="text-xs font-semibold uppercase tracking-widest mb-3 opacity-60"
      >
        La empresa
      </p>
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">Sobre Nosotros</h1>
      <p class="text-white/70 max-w-xl mx-auto text-base leading-relaxed">
        Más de 15 años cuidando la operación de las empresas más importantes de
        la Zona Metropolitana de Monterrey.
      </p>
    </div>
  </div>

  <!-- Propuesta de valor: HardWare ofrece soluciones integrales -->
  <ValueProposition client:visible />

  <!-- Bento content -->
  <AboutBento client:visible />
</Layout>
