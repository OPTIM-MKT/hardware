---
import Layout from "../layouts/Layout.astro";
import HeroCarousel from "../components/home/HeroCarousel";
import ServicesSection from "../components/home/ServicesSection";
import PartnersSection from "../components/home/PartnersSection";
import HomeContactTeaser from "../components/home/HomeContactTeaser";
---

<Layout
  title="Hard-Ware | Reparación y Mantenimiento Industrial"
  description="Expertos en reparación de equipos industriales de control, mantenimiento de dispositivos móviles y gestión de garantías en Monterrey, N.L."
>
  <!-- Hero Swiper full-screen -->
  <HeroCarousel client:load />

  <!-- Partners / Alianzas -->
  <PartnersSection client:visible />

  <!-- Services bento grid -->
  <ServicesSection client:visible />

  <!-- Contact teaser -->
  <HomeContactTeaser client:visible />
</Layout>
