---
import Layout from "../layouts/Layout.astro";
import HeroCarousel from "../components/home/HeroCarousel";
import ServicesSection from "../components/home/ServicesSection";
import BrandsGrid from "../components/home/BrandsGrid";
import HomeContactTeaser from "../components/home/HomeContactTeaser";
---

<Layout
  title="Hard-Ware | Soluciones Industriales en Tecnología, Impresión e Identificación para Empresas en México"
  description="Soluciones industriales en tecnología, impresión, identificación y automatización para empresas en México. Distribuidor autorizado Zebra, Honeywell, SATO y más."
>
  <!-- Hero B2B -->
  <HeroCarousel client:load />

  <!-- Brands / Distribuidores Autorizados -->
  <BrandsGrid client:visible />

  <!-- Services bento grid -->
  <ServicesSection client:visible />

  <!-- Contact teaser -->
  <HomeContactTeaser client:visible />
</Layout>
