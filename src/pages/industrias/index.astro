---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import FeatureCard from "../../components/shared/FeatureCard";

const industrias = await getCollection("industrias");
const PLACEHOLDER =
  "https://images.unsplash.com/photo-1516937941344-00b4e0337589?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D";
---

<Layout
  title="Industrias | Soluciones HardWare por sector | Distribuidor autorizado en México"
  description="Soluciones tecnológicas por industria: manufactura, logística, almacenes, retail, salud, ingeniería CAD, gobierno y operaciones exteriores. HardWare es distribuidor autorizado en México."
>
  <section
    class="py-20"
    style="background: linear-gradient(135deg, #013383 0%, #0a1a40 60%, #233060 100%);"
  >
    <div class="container-lg text-center">
      <span
        class="inline-block px-4 py-1.5 text-xs font-bold uppercase tracking-widest rounded-full mb-6"
        style="background: rgba(250,183,2,0.15); color: #fab702;"
      >
        Industrias que atendemos
      </span>
      <h1
        class="text-4xl md:text-5xl font-extrabold text-white mb-4 leading-tight"
      >
        Tecnología para cada industria
      </h1>
      <p class="text-white/70 text-base max-w-2xl mx-auto leading-relaxed">
        HardWare es distribuidor autorizado en México. Diseñamos soluciones
        específicas para los retos de cada sector: manufactura, logística,
        almacenes, retail, salud, ingeniería CAD, gobierno y operaciones
        exteriores.
      </p>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-lg">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          industrias.map((i) => (
            <FeatureCard
              imagen={i.data.imagen ?? PLACEHOLDER}
              titulo={i.data.titulo ?? i.data.nombre}
              descripcion={i.data.descripcion}
              href={`/industrias/${i.id}`}
              eyebrow="Industria"
              ctaLabel="Ver soluciones"
            />
          ))
        }
      </div>
    </div>
  </section>
</Layout>
