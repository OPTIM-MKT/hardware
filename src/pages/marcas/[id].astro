---
import { getCollection, getEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import ContactForm from "../../components/contact/ContactForm";

export const prerender = true;

export async function getStaticPaths() {
  const marcas = await getCollection("marcas");
  return marcas.map((m) => ({ params: { id: m.id } }));
}

const { id } = Astro.params;
const marca = await getEntry("marcas", id!);
if (!marca) return Astro.redirect("/404");

interface ProductoCard {
  nombre: string;
  imagen: string;
  slug?: string;
  descripcion?: string;
}

const productosCollection = await getCollection("productos");
const productosFromCollection: ProductoCard[] = productosCollection
  .filter((p) => p.data.marca === id)
  .map((p) => ({
    nombre: p.data.nombre,
    imagen: p.data.imagen ?? "",
    slug: p.id,
    descripcion: p.data.descripcion,
  }));

const productosFromFrontmatter: ProductoCard[] = marca.data.productos.map((p) => ({
  nombre: p.nombre,
  imagen: p.imagen,
  slug: p.slug,
  descripcion: p.descripcion,
}));

const productosMap = new Map<string, ProductoCard>();
for (const p of [...productosFromFrontmatter, ...productosFromCollection]) {
  const key = p.slug ?? p.nombre;
  if (!productosMap.has(key)) productosMap.set(key, p);
}
const productos = Array.from(productosMap.values());

const productOptions = productos.map((p) => ({
  value: p.slug ?? p.nombre,
  label: p.nombre,
}));

const defaultProduct = productOptions[0]?.value ?? "";
---

<Layout
  title={`${marca.data.nombre} | Distribuidor Autorizado en México | Hard-Ware`}
  description={marca.data.descripcion}
>
  <!-- Brand Hero -->
  <section
    class="relative overflow-hidden"
    style="background: linear-gradient(135deg, #013383 0%, #0a1a40 60%, #233060 100%);"
  >
    <div
      class="absolute inset-0 opacity-[0.04] pointer-events-none"
      style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(90deg, #fff 1px, transparent 1px); background-size: 40px 40px;"
    >
    </div>
    <div
      class="absolute -top-32 -right-32 w-96 h-96 rounded-full blur-3xl opacity-10 pointer-events-none"
      style="background: #fab702;"
    >
    </div>

    <div class="container-lg section-padding relative z-10">
      <nav
        aria-label="Breadcrumb"
        class="flex items-center gap-2 text-xs text-white/50 mb-10"
      >
        <a href="/" class="hover:text-white transition-colors">Inicio</a>
        <span>/</span>
        <a href="/marcas" class="hover:text-white transition-colors">Marcas</a>
        <span>/</span>
        <span class="text-white/80">{marca.data.nombre}</span>
      </nav>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div class="flex flex-col gap-6">
          <div
            class="w-20 h-20 rounded-2xl flex items-center justify-center font-black text-2xl tracking-widest"
            style="background: #fab702; color: #013383;"
          >
            {marca.data.nombre.slice(0, 3).toUpperCase()}
          </div>

          <div class="inline-flex items-center gap-2 w-fit">
            <span
              class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-bold uppercase tracking-widest text-primary"
              style="background: #fab702;"
            >
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z"
                  clip-rule="evenodd"></path>
              </svg>
              HardWare es distribuidor autorizado en México
            </span>
          </div>

          <h1 class="text-4xl md:text-5xl font-extrabold text-white leading-tight">
            {marca.data.nombre}
          </h1>
          <p class="text-white/70 text-base leading-relaxed max-w-lg">
            {marca.data.descripcion}
          </p>

          {
            marca.data.categorias.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {marca.data.categorias.map((cat) => (
                  <span class="px-3 py-1 rounded-full text-xs font-medium border border-white/20 text-white/70">
                    {cat}
                  </span>
                ))}
              </div>
            )
          }

          <div class="flex flex-wrap gap-3 mt-2">
            <a
              href="#productos"
              class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full font-semibold text-sm uppercase tracking-widest text-primary hover:-translate-y-0.5 hover:shadow-xl transition-all duration-300"
              style="background: #fab702;"
            >
              Ver productos
            </a>
            {
              marca.data.sitioWeb && (
                <a
                  href={marca.data.sitioWeb}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full font-semibold text-sm text-white border border-white/30 hover:border-white/60 hover:bg-white/10 transition-all duration-300"
                >
                  Sitio oficial
                </a>
              )
            }
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          {
            [
              {
                value: String(productos.length),
                label: "Productos disponibles",
                icon: "📦",
              },
              {
                value: marca.data.distribuidorAutorizadoMX ? "✓" : "Alianza",
                label: marca.data.distribuidorAutorizadoMX
                  ? "Distribuidor Autorizado MX"
                  : "Disponible vía alianza",
                icon: "🏅",
              },
              { value: "+5 años", label: "Alianza comercial", icon: "🤝" },
              { value: "MX", label: "Cobertura nacional", icon: "📍" },
            ].map((stat) => (
              <div class="p-5 rounded-2xl border border-white/10 bg-white/5 flex flex-col gap-2">
                <span class="text-2xl">{stat.icon}</span>
                <span class="text-2xl font-extrabold text-white leading-none">
                  {stat.value}
                </span>
                <span class="text-xs text-white/50 leading-tight">
                  {stat.label}
                </span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Catálogo de productos de esta marca -->
  <section id="productos" class="section-padding scroll-mt-20">
    <div class="container-lg">
      <div class="mb-12">
        <span
          class="inline-block px-3 py-1 text-[10px] font-bold uppercase tracking-widest rounded-full mb-3"
          style="background: rgba(250,183,2,0.12); color: #fab702;"
        >
          Catálogo
        </span>
        <h2 class="text-3xl font-extrabold text-ink">
          Productos {marca.data.nombre}
        </h2>
        <p class="text-muted text-sm mt-2">
          {
            productos.length === 0
              ? "Pronto agregaremos el catálogo completo. Contáctanos para más información."
              : `${productos.length} producto${productos.length !== 1 ? "s" : ""} disponible${productos.length !== 1 ? "s" : ""}`
          }
        </p>
      </div>

      {
        productos.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {productos.map((p) => {
              const href = `#cotizar`;
              return (
                <a
                  href={href}
                  class="group bento-card flex flex-col gap-4 hover:border-accent/50 transition-colors p-0 overflow-hidden"
                >
                  <div class="w-full h-44 overflow-hidden bg-canvas shrink-0">
                    <img
                      src={p.imagen}
                      alt={p.nombre}
                      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                  <div class="flex flex-col gap-2 flex-1 px-6 pb-6">
                    <h3 class="font-bold text-ink group-hover:text-primary dark:group-hover:text-accent transition-colors text-base leading-snug">
                      {p.nombre}
                    </h3>
                    {p.descripcion && (
                      <p class="text-muted text-xs leading-relaxed line-clamp-2">
                        {p.descripcion}
                      </p>
                    )}
                      <span class="mt-auto inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-widest text-primary dark:text-accent group-hover:gap-3 transition-all">
                        Cotizar producto
                      <svg
                        class="w-3 h-3"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
                        />
                      </svg>
                    </span>
                  </div>
                </a>
              );
            })}
          </div>
        ) : (
          <div class="py-20 text-center rounded-3xl border border-dashed border-line text-muted">
            <p class="text-4xl mb-4">📦</p>
            <p class="font-semibold text-ink mb-1">Catálogo en construcción</p>
            <p class="text-sm">
              Contáctanos para conocer disponibilidad y precios.
            </p>
          </div>
        )
      }
    </div>
  </section>

  <!-- Confianza y contacto -->
  <section class="section-padding bg-slate-50 dark:bg-blue-900/10">
    <div class="container-lg">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div class="flex flex-col gap-5">
          <span
            class="inline-block px-3 py-1 text-[10px] font-bold uppercase tracking-widest rounded-full w-fit"
            style="background: rgba(250,183,2,0.12); color: #fab702;"
          >
            HardWare es distribuidor autorizado en México
          </span>
          <h2 class="text-3xl md:text-4xl font-extrabold text-ink leading-tight">
            ¿Necesitas un producto {marca.data.nombre}?
          </h2>
          <p class="text-muted text-base leading-relaxed">
            Cuéntanos qué necesitas. Nuestro equipo te enviará una propuesta
            personalizada con precios de distribuidor, garantía oficial y
            asesoría técnica gratuita.
          </p>
          <ul class="space-y-3 mt-2">
            {
              [
                "Precios oficiales de distribuidor",
                "Garantía de fábrica respaldada",
                "Asesoría técnica gratuita pre y post venta",
                "Capacidad para pedidos a gran escala",
              ].map((item) => (
                <li class="flex items-center gap-3 text-sm text-ink">
                  <span
                    class="w-5 h-5 rounded-full flex items-center justify-center shrink-0 text-primary text-xs font-bold"
                    style="background: rgba(250,183,2,0.2);"
                  >
                    ✓
                  </span>
                  {item}
                </li>
              ))
            }
          </ul>
        </div>
        <div id="cotizar">
          <ContactForm
            client:visible
            productOptions={productOptions}
            defaultProduct={defaultProduct}
            title={`Cotizar productos ${marca.data.nombre}`}
            subtitle="Te respondemos en menos de 24 h hábiles con propuesta y disponibilidad."
            submitLabel="Solicitar cotización"
          />
        </div>
      </div>
    </div>
  </section>
</Layout>
