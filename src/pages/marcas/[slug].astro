---
import { getCollection, getEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import QuoteForm from "../../components/productos/QuoteForm";

// ── Data fetching (SSR) ────────────────────────────────────────────────────
const { slug } = Astro.params;
const marca = await getEntry("marcas", slug);
if (!marca) return Astro.redirect("/404");

// Get all products belonging to this brand
const todosProductos = await getCollection("productos");
const productos = todosProductos.filter((p) => p.data.marca === slug);
---

<Layout
  title={`${marca.data.nombre} | Distribuidor Autorizado | Hard-Ware`}
  description={marca.data.descripcion}
>
  <!-- ── Brand Hero ─────────────────────────────────── -->
  <section
    class="relative overflow-hidden"
    style="background: linear-gradient(135deg, #013383 0%, #0a1a40 60%, #233060 100%);"
  >
    <!-- Grid texture overlay -->
    <div
      class="absolute inset-0 opacity-[0.04] pointer-events-none"
      style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(90deg, #fff 1px, transparent 1px); background-size: 40px 40px;"
    ></div>

    <!-- Accent glow -->
    <div
      class="absolute -top-32 -right-32 w-96 h-96 rounded-full blur-3xl opacity-10 pointer-events-none"
      style="background: #fab702;"
    ></div>

    <div class="container-lg section-padding relative z-10">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-xs text-white/50 mb-10">
        <a href="/" class="hover:text-white transition-colors">Inicio</a>
        <span>/</span>
        <a href="/marcas" class="hover:text-white transition-colors">Marcas</a>
        <span>/</span>
        <span class="text-white/80">{marca.data.nombre}</span>
      </nav>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <!-- Brand identity -->
        <div class="flex flex-col gap-6">
          <!-- Logo placeholder / monogram -->
          <div
            class="w-20 h-20 rounded-2xl flex items-center justify-center font-black text-2xl tracking-widest"
            style="background: #fab702; color: #013383;"
          >
            {marca.data.nombre.slice(0, 3).toUpperCase()}
          </div>

          <!-- Distributor badge -->
          {marca.data.distribuidorAutorizadoMX && (
            <div class="inline-flex items-center gap-2 w-fit">
              <span
                class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-bold uppercase tracking-widest text-primary"
                style="background: #fab702;"
              >
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                </svg>
                Distribuidor Autorizado en México
              </span>
            </div>
          )}

          <h1 class="text-4xl md:text-5xl font-extrabold text-white leading-tight">
            {marca.data.nombre}
          </h1>
          <p class="text-white/70 text-base leading-relaxed max-w-lg">
            {marca.data.descripcion}
          </p>

          <!-- Category chips -->
          {marca.data.categorias.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {marca.data.categorias.map((cat) => (
                <span class="px-3 py-1 rounded-full text-xs font-medium border border-white/20 text-white/70">
                  {cat}
                </span>
              ))}
            </div>
          )}

          <!-- CTAs -->
          <div class="flex flex-wrap gap-3 mt-2">
            <a
              href="#productos"
              class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full font-semibold text-sm uppercase tracking-widest text-primary hover:-translate-y-0.5 hover:shadow-xl transition-all duration-300"
              style="background: #fab702;"
            >
              Ver productos
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3" />
              </svg>
            </a>
            {marca.data.sitioWeb && (
              <a
                href={marca.data.sitioWeb}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full font-semibold text-sm text-white border border-white/30 hover:border-white/60 hover:bg-white/10 transition-all duration-300"
              >
                Sitio oficial
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                </svg>
              </a>
            )}
          </div>
        </div>

        <!-- Credibility stats -->
        <div class="grid grid-cols-2 gap-4">
          {[
            { value: String(productos.length), label: "Productos disponibles", icon: "📦" },
            { value: marca.data.distribuidorAutorizadoMX ? "✓" : "—", label: "Distribuidor Autorizado MX", icon: "🏅" },
            { value: "+5 años", label: "Alianza comercial", icon: "🤝" },
            { value: "ZMM", label: "Cobertura de servicio", icon: "📍" },
          ].map((stat) => (
            <div class="p-5 rounded-2xl border border-white/10 bg-white/5 flex flex-col gap-2">
              <span class="text-2xl">{stat.icon}</span>
              <span class="text-2xl font-extrabold text-white leading-none">{stat.value}</span>
              <span class="text-xs text-white/50 leading-tight">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── Product Catalog ────────────────────────────── -->
  <section id="productos" class="section-padding scroll-mt-20">
    <div class="container-lg">
      <div class="mb-12">
        <span
          class="inline-block px-3 py-1 text-[10px] font-bold uppercase tracking-widest rounded-full mb-3"
          style="background: rgba(250,183,2,0.12); color: #fab702;"
        >
          Catálogo
        </span>
        <h2 class="text-3xl font-extrabold text-ink">
          Productos {marca.data.nombre}
        </h2>
        <p class="text-muted text-sm mt-2">
          {productos.length === 0
            ? "Pronto agregaremos el catálogo completo. Contáctanos para más información."
            : `${productos.length} producto${productos.length !== 1 ? "s" : ""} disponible${productos.length !== 1 ? "s" : ""}`}
        </p>
      </div>

      {productos.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {productos.map((p) => (
            <a
              href={`/productos/${p.id}`}
              class="group bento-card flex flex-col gap-4 hover:border-accent/50 transition-colors"
            >
              <!-- Thumbnail -->
              <div class="w-full h-44 rounded-xl overflow-hidden bg-canvas shrink-0">
                {p.data.imagen ? (
                  <img
                    src={p.data.imagen}
                    alt={p.data.nombre}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-4xl text-muted">
                    📦
                  </div>
                )}
              </div>

              <!-- Info -->
              <div class="flex flex-col gap-2 flex-1">
                {p.data.categoria && (
                  <span class="text-[10px] font-bold uppercase tracking-widest text-accent">
                    {p.data.categoria}
                  </span>
                )}
                <h3 class="font-bold text-ink group-hover:text-primary dark:group-hover:text-accent transition-colors text-base leading-snug">
                  {p.data.nombre}
                </h3>
                <p class="text-muted text-xs leading-relaxed line-clamp-2">
                  {p.data.descripcion}
                </p>
              </div>

              <!-- Footer row -->
              <div class="flex items-center justify-between mt-auto pt-3 border-t border-line">
                <span class="text-xs font-semibold text-muted">
                  {p.data.disponible ? "Disponible" : "Consultar"}
                </span>
                <span class="inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-widest text-primary dark:text-accent group-hover:gap-3 transition-all">
                  Ver producto
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="py-20 text-center rounded-3xl border border-dashed border-line text-muted">
          <p class="text-4xl mb-4">📦</p>
          <p class="font-semibold text-ink mb-1">Catálogo en construcción</p>
          <p class="text-sm">Contáctanos para conocer disponibilidad y precios.</p>
          <a
            href="/contact"
            class="mt-6 inline-flex items-center gap-2 px-7 py-3 rounded-full font-semibold text-sm text-primary"
            style="background: #fab702;"
          >
            Contactar
          </a>
        </div>
      )}
    </div>
  </section>

  <!-- ── Distributor trust band ─────────────────────── -->
  {marca.data.distribuidorAutorizadoMX && (
    <section class="py-12 bg-slate-50 dark:bg-blue-900/10">
      <div class="container-lg">
        <div
          class="rounded-3xl p-8 md:p-12 flex flex-col md:flex-row items-center gap-8 text-white"
          style="background: linear-gradient(135deg, #013383 0%, #233060 100%);"
        >
          <div class="flex-1">
            <p class="text-xs font-bold uppercase tracking-widest text-accent mb-2">
              Garantía de autenticidad
            </p>
            <h3 class="text-2xl font-extrabold mb-2">
              Distribuidor Autorizado Oficial de {marca.data.nombre} en México
            </h3>
            <p class="text-white/70 text-sm leading-relaxed max-w-lg">
              Al comprar con Hard-Ware, recibes productos 100% originales con garantía de fábrica, soporte técnico especializado y acceso a programas de servicio directo del fabricante.
            </p>
          </div>
          <a
            href="#quote-form"
            class="shrink-0 inline-flex items-center gap-2 px-8 py-4 rounded-full font-bold text-sm uppercase tracking-widest text-primary hover:-translate-y-0.5 hover:shadow-xl transition-all duration-300"
            style="background: #fab702;"
          >
            Solicitar Cotización
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- ── Quote Form ─────────────────────────────────── -->
  <section class="section-padding">
    <div class="container-lg">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
        <div class="flex flex-col gap-4">
          <h2 class="text-3xl font-extrabold text-ink">
            ¿Necesitas un producto {marca.data.nombre}?
          </h2>
          <p class="text-muted text-base leading-relaxed">
            Cuéntanos qué necesitas y te enviamos una propuesta personalizada.
          </p>
          <ul class="space-y-3 mt-2">
            {["Precios de distribuidor", "Garantía oficial", "Asesoría técnica gratuita", "Entrega en ZMM"].map((item) => (
              <li class="flex items-center gap-3 text-sm text-ink">
                <span class="w-5 h-5 rounded-full flex items-center justify-center shrink-0 text-primary text-xs font-bold" style="background: rgba(250,183,2,0.2);">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <QuoteForm
          client:visible
          initialCategory={marca.data.categorias[0]}
        />
      </div>
    </div>
  </section>
</Layout>
