---
import { getCollection, getEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const marcas = await getCollection("marcas");
---

<Layout
  title="Marcas | Distribuidores Autorizados | Hard-Ware"
  description="Distribuidores autorizados de Zebra, Honeywell, SATO, Datalogic y más marcas líderes en tecnología industrial para empresas en México."
>
  <!-- Header -->
  <section
    class="py-20"
    style="background: linear-gradient(135deg, #013383 0%, #0a1a40 60%, #233060 100%);"
  >
    <div class="container-lg text-center">
      <span
        class="inline-block px-4 py-1.5 text-xs font-bold uppercase tracking-widest rounded-full mb-6"
        style="background: rgba(250,183,2,0.15); color: #fab702;"
      >
        Distribuidores Autorizados
      </span>
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4 leading-tight">
        Marcas que representamos
      </h1>
      <p class="text-white/70 text-base max-w-xl mx-auto leading-relaxed">
        Alianzas directas con los fabricantes líderes en tecnología industrial, impresión e identificación automática para empresas en México.
      </p>
    </div>
  </section>

  <!-- Grid -->
  <section class="section-padding">
    <div class="container-lg">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {marcas.map((marca) => (
          <a
            href={`/marcas/${marca.id}`}
            class="group bento-card flex flex-col gap-5 hover:border-accent/50 transition-colors relative"
          >
            {marca.data.distribuidorAutorizadoMX && (
              <span
                class="absolute top-4 right-4 inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest text-primary"
                style="background: #fab702;"
              >
                ✓ Autorizado MX
              </span>
            )}
            <div
              class="w-16 h-16 rounded-2xl flex items-center justify-center font-black text-lg tracking-widest shrink-0 transition-transform duration-300 group-hover:scale-110"
              style="background: var(--color-primary); color: var(--color-accent);"
            >
              {marca.data.nombre.slice(0, 3).toUpperCase()}
            </div>
            <div>
              <h2 class="text-xl font-extrabold text-ink group-hover:text-primary dark:group-hover:text-accent transition-colors mb-1">
                {marca.data.nombre}
              </h2>
              <p class="text-muted text-sm leading-relaxed line-clamp-2">
                {marca.data.descripcion}
              </p>
            </div>
            {marca.data.categorias.length > 0 && (
              <div class="flex flex-wrap gap-2 mt-auto">
                {marca.data.categorias.map((cat) => (
                  <span class="px-2.5 py-1 rounded-full text-[10px] font-medium border border-line text-muted">
                    {cat}
                  </span>
                ))}
              </div>
            )}
            <span class="inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-widest text-primary dark:text-accent group-hover:gap-3 transition-all">
              Ver productos
              <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
