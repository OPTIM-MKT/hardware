---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import AddToCartButton from "../../components/cart/AddToCartButton";
import RelatedProducts, {
  type RelatedProduct,
} from "../../components/productos/RelatedProducts";
import ContactForm from "../../components/contact/ContactForm";
import ProductsDisclaimer from "../../components/productos/ProductsDisclaimer.astro";

export const prerender = true;

export async function getStaticPaths() {
  const productos = await getCollection("productos");
  return productos.map((p) => ({ params: { slug: p.id }, props: { product: p } }));
}

const { product } = Astro.props;
const { Content } = await render(product);
const { data } = product;

// Recomendados: misma categoría primero, completar con misma marca
const all = await getCollection("productos");
const others = all.filter((p) => p.id !== product.id);

const sameCategory = others.filter((p) => p.data.categoria === data.categoria);
const sameBrand = others.filter(
  (p) => p.data.marca === data.marca && p.data.categoria !== data.categoria
);

const recommendedSource = [...sameCategory, ...sameBrand].slice(0, 4);

const recommended: RelatedProduct[] = recommendedSource.map((p) => ({
  slug: p.id,
  nombre: p.data.nombre,
  marca: p.data.marca,
  categoria: p.data.categoria,
  descripcion: p.data.descripcion,
  imagen: p.data.imagen,
  sku: p.data.sku,
}));

const cartProduct = {
  slug: product.id,
  nombre: data.nombre,
  marca: data.marca,
  imagen: data.imagen,
  categoria: data.categoria,
  sku: data.sku,
};
---

<Layout
  title={`${data.nombre} | Hard-Ware`}
  description={data.descripcion}
  image={data.imagen}
>
  <section class="pt-12 pb-8 md:pt-20 md:pb-12">
    <div class="container-lg">
      <nav class="text-xs text-muted mb-6 flex items-center gap-2" aria-label="Migas de pan">
        <a href="/" class="hover:text-primary transition-colors">Inicio</a>
        <span>/</span>
        <a href="/productos" class="hover:text-primary transition-colors">Productos</a>
        <span>/</span>
        <span class="text-ink dark:text-white line-clamp-1">{data.nombre}</span>
      </nav>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-14 items-start">
        <div class="bento-card p-0 overflow-hidden">
          <div class="aspect-square bg-line relative">
            {
              data.imagen && (
                <img
                  src={data.imagen}
                  alt={data.nombre}
                  class="w-full h-full object-cover"
                />
              )
            }
            <div class="absolute top-4 left-4 flex flex-col gap-2">
              {
                data.nuevo && (
                  <span class="text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full bg-accent text-primary">
                    Nuevo
                  </span>
                )
              }
              {
                data.destacado && (
                  <span class="text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full bg-primary text-white">
                    Destacado
                  </span>
                )
              }
            </div>
          </div>
        </div>

        <div class="flex flex-col gap-5">
          <div>
            <p class="text-[10px] font-semibold uppercase tracking-widest text-muted mb-2">
              {data.marca} · {data.categoria}
            </p>
            <h1 class="text-3xl md:text-4xl font-extrabold text-ink dark:text-white mb-3 leading-tight">
              {data.nombre}
            </h1>
            <p class="text-base text-muted leading-relaxed">{data.descripcion}</p>
          </div>

          {
            data.descripcionLarga && (
              <p class="text-sm text-muted leading-relaxed">{data.descripcionLarga}</p>
            )
          }

          {
            data.caracteristicas.length > 0 && (
              <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-4 gap-y-2 list-none p-0 m-0">
                {data.caracteristicas.map((c) => (
                  <li class="flex items-start gap-2 text-sm text-ink dark:text-white">
                    <svg
                      class="w-4 h-4 mt-0.5 text-accent shrink-0"
                      fill="none"
                      stroke="currentColor"
                      stroke-width={2.5}
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="m4.5 12.75 6 6 9-13.5"
                      />
                    </svg>
                    <span>{c}</span>
                  </li>
                ))}
              </ul>
            )
          }

          <div class="flex items-center gap-3 pt-2">
            {
              data.disponible ? (
                <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-emerald-600">
                  <span class="w-2 h-2 rounded-full bg-emerald-500" /> Disponible
                </span>
              ) : (
                <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-red-500">
                  <span class="w-2 h-2 rounded-full bg-red-500" /> Agotado
                </span>
              )
            }
            {
              data.sku && (
                <span class="text-xs text-muted">SKU: {data.sku}</span>
              )
            }
          </div>

          <AddToCartButton
            product={cartProduct}
            showQuantity={true}
            client:load
          />

          <p class="text-xs text-muted">
            Solicita tu cotización personalizada · respuesta en menos de 24 h hábiles.
          </p>
        </div>
      </div>
    </div>
  </section>

  {
    data.especificaciones.length > 0 && (
      <section class="section-padding bg-slate-50 dark:bg-slate-950">
        <div class="container-lg">
          <h2 class="text-2xl md:text-3xl font-bold text-ink dark:text-white mb-8">
            Especificaciones técnicas
          </h2>
          <div class="bento-card p-0 overflow-hidden">
            <dl class="divide-y divide-line">
              {data.especificaciones.map((spec) => (
                <div class="grid grid-cols-1 md:grid-cols-[200px_1fr] gap-2 p-5">
                  <dt class="text-xs font-semibold uppercase tracking-widest text-muted">
                    {spec.label}
                  </dt>
                  <dd class="text-sm text-ink dark:text-white m-0">{spec.value}</dd>
                </div>
              ))}
            </dl>
          </div>
        </div>
      </section>
    )
  }

  <article class="container-lg my-16 prose prose-slate dark:prose-invert max-w-3xl">
    <Content />
  </article>

  <RelatedProducts products={recommended} client:visible />

  <section class="container-lg pt-12">
    <ProductsDisclaimer />
  </section>

  <section class="section-padding">
    <div class="container-lg">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 items-start">
        <div class="lg:col-span-2">
          <p class="text-[10px] font-semibold uppercase tracking-widest text-muted mb-2">
            Cotiza este producto
          </p>
          <h2 class="text-2xl md:text-3xl font-bold text-black dark:text-white mb-4 leading-tight">
            ¿Listo para integrar <span class="text-primary dark:text-accent">{data.nombre}</span> en tu operación?
          </h2>
          <p class="text-sm text-muted leading-relaxed mb-4">
            Agrégalo al carrito y completa el formulario; nuestro equipo te
            envía una propuesta personalizada en menos de 24 h hábiles. Si
            necesitas integrarlo con otros productos o asesoría técnica,
            cuéntanos en los comentarios.
          </p>
          <ul class="space-y-2 list-none p-0 m-0">
            {[
              "Distribuidor autorizado en México",
              "Propuesta económica + técnica",
              "Asesoría sobre integración y volumen",
            ].map((bullet) => (
              <li class="flex items-start gap-2 text-sm text-ink dark:text-white">
                <svg
                  class="w-4 h-4 mt-0.5 text-accent shrink-0"
                  fill="none"
                  stroke="currentColor"
                  stroke-width={2.5}
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="m4.5 12.75 6 6 9-13.5"
                  />
                </svg>
                <span>{bullet}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="lg:col-span-3">
          <ContactForm initialMode="productos" client:visible />
        </div>
      </div>
    </div>
  </section>
</Layout>
