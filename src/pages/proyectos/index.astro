---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("blogs")).sort(
  (a, b) => b.data.fecha.getTime() - a.data.fecha.getTime(),
);
const dateFormatter = new Intl.DateTimeFormat("es-MX", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<Layout
  title="Blog | Hard-Ware – Tecnología industrial, guías y casos de éxito"
  description="Recursos, guías técnicas y noticias del ecosistema de tecnología industrial: impresión, identificación, captura de datos y automatización."
>
  <section
    class="w-full py-16 md:py-24 text-white"
    style="background: linear-gradient(135deg, #013383 0%, #233060 100%);"
  >
    <div class="container-lg text-center">
      <p
        class="text-xs font-semibold uppercase tracking-widest mb-3 opacity-60"
      >
        Recursos
      </p>
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">
        Proyectos HardWare
      </h1>
      <p class="text-white/70 max-w-xl mx-auto text-base leading-relaxed">
        Guías técnicas, casos de éxito y novedades del ecosistema industrial.
      </p>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-lg">
      {
        posts.length === 0 ? (
          <div class="bento-card text-center py-16">
            <p class="text-base font-semibold text-ink dark:text-white">
              Pronto tendremos contenido
            </p>
            <p class="text-sm text-muted mt-2">
              Estamos preparando guías y artículos para ayudarte a sacar más
              provecho de tu operación.
            </p>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {posts.map((post) => (
              <a
                href={`/proyectos/${post.id}`}
                class="group bento-card flex flex-col gap-4 p-5 hover:border-primary/30 transition-all"
              >
                <div class="aspect-video rounded-xl overflow-hidden bg-line">
                  {post.data.portada && (
                    <img
                      src={post.data.portada}
                      alt={post.data.titulo}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                    />
                  )}
                </div>
                <div class="flex flex-col gap-2 flex-1">
                  <p class="text-[10px] font-semibold uppercase tracking-widest text-muted">
                    {post.data.categoria ?? "Artículo"} ·{" "}
                    {dateFormatter.format(post.data.fecha)}
                  </p>
                  <h2 class="text-lg font-bold text-ink dark:text-white line-clamp-2 group-hover:text-primary transition-colors">
                    {post.data.titulo}
                  </h2>
                  <p class="text-sm text-muted line-clamp-3">
                    {post.data.descripcion}
                  </p>
                </div>
                <span class="inline-flex items-center gap-1 text-xs font-semibold uppercase tracking-widest text-primary dark:text-accent">
                  Leer artículo
                  <svg
                    class="w-3 h-3"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
                    />
                  </svg>
                </span>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>
</Layout>
