---
import { getCollection, getEntry, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import TaxonomyDetail from "../../components/shared/TaxonomyDetail.astro";

export const prerender = true;

export async function getStaticPaths() {
  const soluciones = await getCollection("soluciones");
  return soluciones.map((s) => ({ params: { id: s.id } }));
}

const { id } = Astro.params;
const solucion = await getEntry("soluciones", id!);
if (!solucion) return Astro.redirect("/404");

const { Content } = await render(solucion);
---

<Layout
  title={`${solucion.data.nombre} | Solución HardWare | Distribuidor autorizado en México`}
  description={solucion.data.descripcion}
>
  <TaxonomyDetail kind="solucion" data={solucion.data} slug={solucion.id}>
    <Content />
  </TaxonomyDetail>
</Layout>
